{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/hive-parser/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/hive-parser/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/hive-parser",
  "projects": {
    "api-service": {
      "type": "application",
      "root": "apps/api-service",
      "entryFile": "main",
      "sourceRoot": "apps/api-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api-service/tsconfig.app.json"
      }
    },
    "clients": {
      "type": "library",
      "root": "libs/clients",
      "entryFile": "index",
      "sourceRoot": "libs/clients/src",
      "compilerOptions": {
        "tsConfigPath": "libs/clients/tsconfig.lib.json"
      }
    },
    "hive-parser": {
      "type": "application",
      "root": "apps/hive-parser",
      "entryFile": "main",
      "sourceRoot": "apps/hive-parser/src",
      "compilerOptions": {
        "tsConfigPath": "apps/hive-parser/tsconfig.app.json"
      }
    },
    "objects-bot": {
      "type": "application",
      "root": "apps/objects-bot",
      "entryFile": "main",
      "sourceRoot": "apps/objects-bot/src",
      "compilerOptions": {
        "tsConfigPath": "apps/objects-bot/tsconfig.app.json"
      }
    }
  }
}